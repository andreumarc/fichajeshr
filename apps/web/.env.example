# =============================================================
# FICHAJE SAAS — Environment Variables (Vercel + Neon)
# Set these in Vercel → Project Settings → Environment Variables
# =============================================================

# ── DATABASE (Neon) ───────────────────────────────────────────
# Pooled connection — used at runtime by Vercel serverless functions
DATABASE_URL="postgresql://[user]:[pass]@[host]-pooler.region.aws.neon.tech/neondb?sslmode=require"
# Direct (non-pooled) — used only for Prisma migrations
DIRECT_URL="postgresql://[user]:[pass]@[host].region.aws.neon.tech/neondb?sslmode=require"

# ── AUTH ──────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="CHANGE_ME_64_CHAR_HEX"
JWT_REFRESH_SECRET="CHANGE_ME_64_CHAR_HEX_DIFFERENT"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# ── APP ───────────────────────────────────────────────────────
NODE_ENV="production"
BCRYPT_ROUNDS=12
PIN_HASH_SECRET="CHANGE_ME_RANDOM_SECRET"

# ── PUBLIC URLS ──────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="https://your-app.vercel.app"
NEXT_PUBLIC_API_URL="https://your-app.vercel.app/api/v1"
NEXT_PUBLIC_KIOSK_URL="https://your-app.vercel.app/kiosk"

# ── SUPERADMIN ───────────────────────────────────────────────
SUPERADMIN_EMAIL="superadmin@fichaje.app"
SUPERADMIN_PASSWORD="CHANGE_ME_STRONG_PASSWORD"

# ── EMAIL (opcional) ─────────────────────────────────────────
SMTP_HOST="smtp.resend.com"
SMTP_PORT=465
SMTP_USER="resend"
SMTP_PASS="re_XXXXXXXXXXXXX"
SMTP_FROM="Fichaje App <noreply@fichaje.app>"
