# =============================================================
# FICHAJE SAAS — Frontend Environment Variables
# Set these in Vercel project → Settings → Environment Variables
# =============================================================

# ── BACKEND ───────────────────────────────────────────────────
# URL of your Railway backend (no trailing slash)
# Used by next.config.mjs rewrites to proxy /api/v1/* requests
BACKEND_URL="https://your-backend.up.railway.app"

# ── PUBLIC URLS ──────────────────────────────────────────────
NEXT_PUBLIC_API_URL="https://your-app.vercel.app/api/v1"
NEXT_PUBLIC_APP_URL="https://your-app.vercel.app"
NEXT_PUBLIC_KIOSK_URL="https://your-app.vercel.app/kiosk"
