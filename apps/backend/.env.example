# =============================================================
# FICHAJE SAAS — Backend Environment Variables
# Copy to .env for local dev, set in Railway for production
# =============================================================

# ── DATABASE (Supabase) ───────────────────────────────────────
# Transaction-mode pooler URL (port 6543) — used at runtime
DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-eu-central-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
# Direct connection (port 5432) — used by Prisma for migrations
DIRECT_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres"

# ── AUTH ──────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="CHANGE_ME_64_CHAR_HEX"
JWT_REFRESH_SECRET="CHANGE_ME_64_CHAR_HEX_DIFFERENT"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# ── BACKEND ───────────────────────────────────────────────────
# Railway sets PORT automatically — leave this as-is
BACKEND_PORT=3001
NODE_ENV="production"
# Comma-separated list of allowed frontend origins
CORS_ORIGINS="https://your-app.vercel.app"
API_PREFIX="api/v1"

# ── FRONTEND URLS ────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="https://your-app.vercel.app"

# ── SECURITY ─────────────────────────────────────────────────
BCRYPT_ROUNDS=12
PIN_HASH_SECRET="CHANGE_ME_RANDOM_SECRET"

# ── RATE LIMITING ─────────────────────────────────────────────
THROTTLE_TTL=60
THROTTLE_LIMIT=100
KIOSK_THROTTLE_LIMIT=200

# ── GEOLOCATION ──────────────────────────────────────────────
DEFAULT_GEOFENCE_RADIUS_METERS=200
GEOFENCE_TOLERANCE_METERS=50

# ── SESSIONS ─────────────────────────────────────────────────
SESSION_MAX_CONCURRENT=5
KIOSK_SESSION_TIMEOUT_SECONDS=30

# ── REDIS (optional) ─────────────────────────────────────────
REDIS_URL=""
REDIS_ENABLED=false

# ── LOGGING ──────────────────────────────────────────────────
LOG_LEVEL="warn"
LOG_TO_FILE=false

# ── EMAIL (Resend / SendGrid / SMTP) ─────────────────────────
SMTP_HOST="smtp.resend.com"
SMTP_PORT=465
SMTP_USER="resend"
SMTP_PASS="re_XXXXXXXXXXXXX"
SMTP_FROM="FichajeHR <noreply@fichajeshr.app>"

# ── SUPERADMIN ───────────────────────────────────────────────
SUPERADMIN_EMAIL="superadmin@fichajeshr.app"
SUPERADMIN_PASSWORD="CHANGE_ME_STRONG_PASSWORD"
