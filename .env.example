# =============================================================
# FICHAJE SAAS - Environment Variables
# Copy this file to .env and fill in values
# =============================================================

# ---- DATABASE ------------------------------------------------
DATABASE_URL="postgresql://fichaje_user:fichaje_pass@localhost:5432/fichaje_db?schema=public"

# ---- AUTH ----------------------------------------------------
JWT_SECRET="your-super-secret-jwt-key-change-in-production-min-64-chars"
JWT_REFRESH_SECRET="your-super-secret-refresh-key-change-in-production-min-64-chars"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# ---- BACKEND -------------------------------------------------
BACKEND_PORT=1000
NODE_ENV="development"
CORS_ORIGINS="http://localhost:1000"
API_PREFIX="api/v1"

# ---- FRONTEND WEB --------------------------------------------
NEXT_PUBLIC_API_URL="http://localhost:1000/api/v1"
NEXT_PUBLIC_APP_URL="http://localhost:1000"
NEXT_PUBLIC_KIOSK_URL="http://localhost:1000/kiosk"

# ---- ENCRYPTION ----------------------------------------------
BCRYPT_ROUNDS=12
PIN_HASH_SECRET="pin-hash-secret-change-in-production"

# ---- RATE LIMITING -------------------------------------------
THROTTLE_TTL=60
THROTTLE_LIMIT=100
KIOSK_THROTTLE_LIMIT=200

# ---- GEOLOCATION --------------------------------------------
DEFAULT_GEOFENCE_RADIUS_METERS=200
GEOFENCE_TOLERANCE_METERS=50

# ---- SESSIONS -----------------------------------------------
SESSION_MAX_CONCURRENT=5
KIOSK_SESSION_TIMEOUT_SECONDS=30

# ---- REDIS (optional, for sessions/cache) -------------------
REDIS_URL="redis://localhost:6379"
REDIS_ENABLED=false

# ---- LOGGING ------------------------------------------------
LOG_LEVEL="debug"
LOG_TO_FILE=false
LOG_FILE_PATH="./logs/app.log"

# ---- UPLOADS ------------------------------------------------
UPLOAD_DIR="./uploads"
MAX_FILE_SIZE_MB=10

# ---- EMAIL (optional) ---------------------------------------
SMTP_HOST="smtp.example.com"
SMTP_PORT=587
SMTP_USER="noreply@fichajeshr.app"
SMTP_PASS="smtp-password"
SMTP_FROM="FichajeHR <noreply@fichajeshr.app>"

# ---- WHATSAPP BUSINESS API ----------------------------------
# Get these from Meta Developer Console: https://developers.facebook.com
WHATSAPP_VERIFY_TOKEN="your-webhook-verify-token"
WHATSAPP_ACCESS_TOKEN="your-whatsapp-access-token"
WHATSAPP_PHONE_NUMBER_ID="your-phone-number-id"
WHATSAPP_API_VERSION="v19.0"
# Webhook URL to register in Meta: https://your-domain.com/api/v1/whatsapp/webhook

# ---- MULTITENANCY -------------------------------------------
SUPERADMIN_EMAIL="superadmin@fichajeshr.app"
SUPERADMIN_PASSWORD="SuperAdmin123!Change"

# ---- POSTGRES (docker-compose) ------------------------------
POSTGRES_DB=fichaje_db
POSTGRES_USER=fichaje_user
POSTGRES_PASSWORD=fichaje_pass
POSTGRES_PORT=5432
