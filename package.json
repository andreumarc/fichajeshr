{
  "name": "fichaje-saas",
  "version": "1.0.0",
  "private": true,
  "packageManager": "npm@11.11.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently --names \"backend,web\" --prefix-colors \"cyan,magenta\" \"npm run dev:backend\" \"npm run dev:web\"",
    "dev:backend": "npm --prefix apps/backend run dev",
    "dev:web": "npm --prefix apps/web run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "db:generate": "cd apps/backend && npx prisma generate",
    "db:migrate": "cd apps/backend && npx prisma migrate dev",
    "db:seed": "cd apps/backend && npx ts-node src/seed/seed.ts",
    "db:studio": "cd apps/backend && npx prisma studio"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "caniuse-lite": "^1.0.30001787",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.4",
    "concurrently": "^8.2.2",
    "node-emoji": "^2.2.0",
    "turbo": "^2.0.0",
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  }
}
